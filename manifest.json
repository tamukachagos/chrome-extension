{
  "manifest_version": 3,
  "name": "Data Analyst AI",
  "description": "AI data analyst for Power BI, Tableau, and SQL — writes measures, audits visuals, executes goals, and tracks KPIs from a persistent side panel.",
  "version": "1.1.0",
  "options_page": "rule-tester.html",
  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "scripting",
    "sidePanel",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://app.powerbi.com/*",
    "https://*.powerbi.com/*",
    "https://*.tableau.com/*",
    "https://public.tableau.com/*",
    "https://api.powerbi.com/*",
    "https://*/*",
    "http://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "side_panel": {
    "default_path": "src/sidepanel.html"
  },
  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Data Analyst AI",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://app.powerbi.com/*",
        "https://*.powerbi.com/*"
      ],
      "js": [
        "src/pbiTokenCapture.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://app.powerbi.com/*",
        "https://*.powerbi.com/*"
      ],
      "js": [
        "src/pbiApi.js"
      ],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://app.powerbi.com/*",
        "https://*.powerbi.com/*"
      ],
      "js": [
        "src/daxEngine.js",
        "src/ruleLoader.js",
        "src/skills.js",
        "src/contentScript.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.tableau.com/*",
        "https://public.tableau.com/*"
      ],
      "js": [
        "src/tableauAdapter.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://app.powerbi.com/*",
        "https://*.powerbi.com/*",
        "https://*.tableau.com/*",
        "https://public.tableau.com/*",
        "https://*/*"
      ],
      "js": [
        "src/platformAdapter.js",
        "src/actionExecutor.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "rules/processed/final_rules.json",
        "rules/processed/compiled_rules.json",
        "rules/performance_rules.json",
        "rules/correctness_rules.json",
        "rules/modeling_rules.json",
        "training/rules_advanced.json",
        "src/daxEngine.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
