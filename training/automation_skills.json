    "selectors_or_detection": ["state.settings.fallbackEndpoint is set", "state.settings.fallbackEnabled is true"],
    "actions": [
      { "type": "screenshot", "target": "visible_tab", "value": "", "reason": "Capture latest state before sending", "requires_approval": false },
      { "type": "vision", "target": "fallback_endpoint", "value": "{prompt}", "reason": "Send screenshot + prompt to Claude for analysis", "requires_approval": false }
    ],
    "success_detection": ["response.text or response.content is non-empty string"],
    "failure_detection": ["HTTP status != 200", "response.error is set", "response body has no text field"],
    "risk_level": "low",
    "requires_llm": true
  },
