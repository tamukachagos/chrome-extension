    "actions": [
      { "type": "wait", "target": "loading_selector", "value": "500", "reason": "Poll for spinner disappearance every 500ms", "requires_approval": false },
      { "type": "wait", "target": "dom_stable", "value": "200", "reason": "Extra buffer after spinner clears for DOM to settle", "requires_approval": false }
    ],
    "success_detection": ["No element matching loading selectors is visible in the DOM"],
    "failure_detection": ["Spinner persists after 10000ms — report may have a data error"],
    "risk_level": "low",
    "requires_llm": false
  },
