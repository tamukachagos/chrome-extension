    "preconditions": ["Extension panel is open", "User is on app.powerbi.com"],
    "selectors_or_detection": ["chrome.tabs.captureVisibleTab available", "TAKE_SCREENSHOT message channel ready"],
    "actions": [
      { "type": "screenshot", "target": "visible_tab", "value": "", "reason": "Capture current report state for vision analysis or action planning", "requires_approval": false }
    ],
    "success_detection": ["response.dataUrl starts with data:image/png;base64"],
    "failure_detection": ["chrome.runtime.lastError is set", "response.error is non-null"],
    "risk_level": "low",
    "requires_llm": false
  },
  {
    "skill": "analyze_screenshot_with_vision",
    "intent": "Send a captured screenshot to Claude via the proxy endpoint for visual analysis",
